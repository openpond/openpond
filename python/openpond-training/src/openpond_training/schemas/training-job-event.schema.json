{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "openpond.trainingJobEvent.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "jobId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "type": {
      "type": "string",
      "enum": [
        "queued",
        "start",
        "progress",
        "metric",
        "checkpoint",
        "cancel",
        "complete",
        "failure",
        "reconcile"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "jobId",
    "sequence",
    "type",
    "timestamp",
    "payload"
  ],
  "additionalProperties": false
}
