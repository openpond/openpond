{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500000
    },
    "chosen": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500000
    },
    "rejected": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500000
    },
    "sourceRefs": {
      "minItems": 1,
      "maxItems": 10000,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    }
  },
  "required": [
    "id",
    "prompt",
    "chosen",
    "rejected",
    "sourceRefs"
  ],
  "additionalProperties": false
}
