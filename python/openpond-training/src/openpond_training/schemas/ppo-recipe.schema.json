{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "openpond.ppoRecipe.v1"
    },
    "method": {
      "type": "string",
      "const": "ppo"
    },
    "parameterization": {
      "type": "string",
      "const": "lora"
    },
    "policyOptimization": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "openpond.policyOptimization.v1"
        },
        "policyModel": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "revision": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "tokenizerRevision": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "chatTemplateHash": {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            }
          },
          "required": [
            "id",
            "revision",
            "tokenizerRevision",
            "chatTemplateHash"
          ],
          "additionalProperties": false
        },
        "referenceModel": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "revision": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "tokenizerRevision": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "chatTemplateHash": {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            }
          },
          "required": [
            "id",
            "revision",
            "tokenizerRevision",
            "chatTemplateHash"
          ],
          "additionalProperties": false
        },
        "dataset": {
          "type": "object",
          "properties": {
            "tasksetId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "tasksetHash": {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            },
            "split": {
              "type": "string",
              "const": "train"
            },
            "selectionStrategy": {
              "type": "string",
              "enum": [
                "stable_hash_top_n",
                "rft_easy_curriculum_v1"
              ]
            },
            "selectionSeed": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991
            },
            "maxExamples": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100000
            }
          },
          "required": [
            "tasksetId",
            "tasksetHash",
            "split",
            "selectionStrategy",
            "selectionSeed",
            "maxExamples"
          ],
          "additionalProperties": false
        },
        "sampler": {
          "type": "object",
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "topP": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "maxOutputTokens": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 32768
            },
            "maxTurns": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 1000
            },
            "concurrency": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 1000
            }
          },
          "required": [
            "temperature",
            "topP",
            "maxOutputTokens",
            "maxTurns",
            "concurrency"
          ],
          "additionalProperties": false
        },
        "environment": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "toolContractHash": {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            }
          },
          "required": [
            "id",
            "version",
            "toolContractHash"
          ],
          "additionalProperties": false
        },
        "reward": {
          "type": "object",
          "properties": {
            "graderId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            "graderHash": {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            }
          },
          "required": [
            "graderId",
            "graderHash"
          ],
          "additionalProperties": false
        },
        "kl": {
          "type": "object",
          "properties": {
            "coefficient": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "referenceConstraint": {
              "type": "string",
              "const": "fixed_reference"
            }
          },
          "required": [
            "coefficient",
            "referenceConstraint"
          ],
          "additionalProperties": false
        },
        "budgets": {
          "type": "object",
          "properties": {
            "maxRollouts": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 1000000
            },
            "maxEnvironmentExecutions": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 1000000
            },
            "maxInputTokens": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "maxOutputTokens": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "maxOptimizerSteps": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 1000000
            },
            "wallTimeMs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "maximumCostUsd": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "maxRollouts",
            "maxEnvironmentExecutions",
            "maxInputTokens",
            "maxOutputTokens",
            "maxOptimizerSteps",
            "wallTimeMs",
            "maximumCostUsd"
          ],
          "additionalProperties": false
        },
        "checkpointEverySteps": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "seed": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "evaluationSplit": {
          "type": "string",
          "const": "frozen_eval"
        },
        "optimizer": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string",
              "const": "ppo"
            },
            "valueModel": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                },
                "revision": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "tokenizerRevision": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "chatTemplateHash": {
                  "type": "string",
                  "minLength": 8,
                  "maxLength": 256
                }
              },
              "required": [
                "id",
                "revision",
                "tokenizerRevision",
                "chatTemplateHash"
              ],
              "additionalProperties": false
            },
            "gamma": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "gaeLambda": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "policyClip": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            },
            "valueClip": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 10
            },
            "valueLossCoefficient": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            },
            "ppoEpochs": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100
            },
            "minibatchSize": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 100000
            }
          },
          "required": [
            "method",
            "valueModel",
            "gamma",
            "gaeLambda",
            "policyClip",
            "valueClip",
            "valueLossCoefficient",
            "ppoEpochs",
            "minibatchSize"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "schemaVersion",
        "policyModel",
        "referenceModel",
        "dataset",
        "sampler",
        "environment",
        "reward",
        "kl",
        "budgets",
        "checkpointEverySteps",
        "seed",
        "evaluationSplit",
        "optimizer"
      ],
      "additionalProperties": false
    },
    "lora": {
      "type": "object",
      "properties": {
        "rank": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 256
        },
        "alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1024
        },
        "dropout": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "targetModules": {
          "minItems": 1,
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      },
      "required": [
        "rank",
        "alpha",
        "dropout",
        "targetModules"
      ],
      "additionalProperties": false
    },
    "valueHead": {
      "type": "object",
      "properties": {
        "initialization": {
          "type": "string",
          "const": "policy_hidden_state_linear"
        },
        "optimizerLearningRate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "artifactName": {
          "type": "string",
          "const": "value_head.safetensors"
        }
      },
      "required": [
        "initialization",
        "optimizerLearningRate",
        "artifactName"
      ],
      "additionalProperties": false
    },
    "policyLearningRate": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "resume": {
      "type": "object",
      "properties": {
        "checkpointId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            },
            {
              "type": "null"
            }
          ]
        },
        "policyHash": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "referenceHash": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "valueModelHash": {
          "type": "string",
          "minLength": 8,
          "maxLength": 256
        },
        "optimizerStateHash": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 256
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "checkpointId",
        "policyHash",
        "referenceHash",
        "valueModelHash",
        "optimizerStateHash"
      ],
      "additionalProperties": false
    },
    "resourceLimits": {
      "type": "object",
      "properties": {
        "cpuThreads": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 256
        },
        "memoryBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "wallTimeMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "cpuThreads",
        "memoryBytes",
        "wallTimeMs"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "method",
    "parameterization",
    "policyOptimization",
    "lora",
    "valueHead",
    "policyLearningRate",
    "resume",
    "resourceLimits"
  ],
  "additionalProperties": false
}
