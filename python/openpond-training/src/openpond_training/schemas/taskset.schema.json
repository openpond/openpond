          "schemaVersion",
          "id",
          "clusterKey",
          "split",
          "input",
          "expectedOutput",
          "policyVisibleContext",
          "privilegedContextRef",
          "sourceRefs",
          "tags",
          "metadata"
        ],
        "additionalProperties": false
      }
