        "requiresTools": {
          "type": "boolean"
        },
        "requiresState": {
          "type": "boolean"
        },
        "requiresPrivilegedGrading": {
          "type": "boolean"
        },
        "environmentPlacements": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "local",
              "remote",
              "colocated",
              "provider_native"
            ]
          }
        },
        "exportable": {
          "type": "boolean"
