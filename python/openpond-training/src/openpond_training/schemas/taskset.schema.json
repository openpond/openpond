        "portabilityBlockers": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          }
        }
      },
      "required": [
        "schemaVersion",
        "taskKind",
        "supportedSignals",
        "compatibleMethods",
        "rewardKinds",
        "requiresTools",
        "requiresState",
        "requiresPrivilegedGrading",
        "environmentPlacements",
        "exportable",
        "portabilityBlockers"
      ],
      "additionalProperties": false
