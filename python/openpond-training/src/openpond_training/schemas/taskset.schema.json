        "schemaVersion": {
          "type": "string",
          "const": "openpond.tasksetCapabilities.v1"
        },
        "taskKind": {
          "type": "string",
          "enum": [
            "chat",
            "single_agent",
            "multi_agent",
            "custom_program"
