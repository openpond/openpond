    "environment": {
      "type": "object",
      "properties": {
        "protocolVersion": {
          "type": "string",
          "const": "openpond.taskEnvironment.v1"
        },
        "kind": {
          "type": "string",
          "enum": [
            "chat",
            "agent",
            "program",
            "stateful_harness"
          ]
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "stateful": {
          "type": "boolean"
        },
        "deterministicSeeds": {
          "type": "boolean"
        },
        "toolNames": {
          "default": [],
          "maxItems": 200,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        },
        "lifecycle": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "create",
              "reset",
              "step",
              "grade",
              "cleanup"
            ]
          }
        },
        "defaultTimeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 3600000
        },
        "networkPolicy": {
          "type": "string",
          "enum": [
            "none",
            "declared_read_only",
            "declared_scoped"
          ]
        },
        "metadata": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "protocolVersion",
        "kind",
        "entrypoint",
        "stateful",
        "deterministicSeeds",
        "toolNames",
        "lifecycle",
