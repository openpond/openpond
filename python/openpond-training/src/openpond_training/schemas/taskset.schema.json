{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "openpond.taskset.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "profileId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "awaiting_disclosure_approval",
        "awaiting_materialization_approval",
        "materializing",
        "validating",
        "needs_review",
        "baselining",
        "ready",
        "blocked",
        "failed",
        "archived"
      ]
    },
    "sourceRefs": {
      "minItems": 1,
      "maxItems": 100000,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schemaVersion": {
            "type": "string",
            "const": "openpond.trainingSource.v1"
          },
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "profileId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "sessionId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "turnIds": {
            "default": [],
            "maxItems": 1000,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "workspaceId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 240
              },
              {
                "type": "null"
              }
            ]
          },
          "sourceHash": {
            "type": "string",
            "minLength": 8,
            "maxLength": 256
          },
          "clusterKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "occurredAt": {
            "type": "string",
            "minLength": 1
          },
          "consent": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "granted",
                  "denied",
                  "revoked"
                ]
              },
              "scope": {
                "type": "string",
                "enum": [
                  "metadata_only",
                  "selected_turns",
                  "full_session"
                ]
              },
              "grantedBy": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 240
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "grantedAt": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "purpose": {
                "type": "string",
                "const": "task_authoring_and_evaluation"
              }
            },
            "required": [
              "status",
              "scope",
              "grantedBy",
              "grantedAt",
              "purpose"
            ],
            "additionalProperties": false
          },
          "connectedAppIds": {
            "default": [],
            "maxItems": 100,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "secretScanStatus": {
            "type": "string",
            "enum": [
              "pending",
              "passed",
              "blocked"
            ]
          },
          "piiScanStatus": {
            "type": "string",
            "enum": [
              "pending",
              "passed",
              "review",
              "blocked"
            ]
          },
          "licensingStatus": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "review",
              "blocked"
            ]
          },
          "metadata": {
            "default": {},
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "schemaVersion",
          "id",
          "profileId",
          "sessionId",
          "turnIds",
          "workspaceId",
          "sourceHash",
          "clusterKey",
          "title",
          "occurredAt",
          "consent",
          "connectedAppIds",
          "secretScanStatus",
          "piiScanStatus",
          "licensingStatus",
          "metadata"
        ],
        "additionalProperties": false
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "policyVisibleFields": {
          "default": [],
          "maxItems": 1000,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
