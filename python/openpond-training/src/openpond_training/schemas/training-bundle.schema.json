{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "openpond.trainingBundle.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "planId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "tasksetId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "tasksetHash": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    },
    "recipeHash": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    },
    "files": {
      "minItems": 1,
      "maxItems": 1000000,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "sha256": {
            "type": "string",
            "minLength": 8,
            "maxLength": 256
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "role": {
            "type": "string",
            "enum": [
              "manifest",
              "task_data",
              "grader",
              "environment",
              "recipe",
              "policy",
              "provenance"
            ]
          }
        },
        "required": [
          "path",
          "sha256",
          "sizeBytes",
          "role"
        ],
        "additionalProperties": false
      }
    },
    "totalSizeBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sourceIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "excludedSourceIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    },
    "containsRawChats": {
      "type": "boolean",
      "const": false
    },
    "containsSecrets": {
      "type": "boolean",
      "const": false
    },
    "containsHiddenGraderAssets": {
      "type": "boolean",
      "const": false
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "contentHash": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "planId",
    "tasksetId",
    "tasksetHash",
    "recipeHash",
    "files",
    "totalSizeBytes",
    "sourceIds",
    "excludedSourceIds",
    "containsRawChats",
    "containsSecrets",
    "containsHiddenGraderAssets",
    "createdAt",
    "contentHash"
  ],
  "additionalProperties": false
}
