{
  "name": "openpond",
  "version": "0.0.22",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19 <21 || >=22.12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun run dev:desktop",
    "desktop": "bun run dev:desktop",
    "dev:server": "bun scripts/dev-runner.ts server",
    "dev:web": "bun scripts/dev-runner.ts web",
    "dev:web:renderer": "bun scripts/dev-runner.ts renderer",
    "dev:desktop": "bun scripts/dev-runner.ts desktop",
    "start": "bun run dev",
    "serve": "bun run build:server && node apps/server/dist/index.js serve",
    "web": "bun run build:web && bun run build:server && node apps/server/dist/index.js web",
    "server": "bun run build:server && node apps/server/dist/index.js",
    "terminal": "bun apps/terminal/src/index.ts chat",
    "typecheck": "tsc -b",
    "typecheck:turn-runner-contract": "tsc -p tests/tsconfig.turn-runner-contract.json",
    "build:cloud": "tsc -b packages/cloud",
    "build:openpond": "bun run build:cloud && bun run --cwd apps/cli build",
    "build:contracts": "tsc -b packages/contracts",
    "build:codex": "tsc -b packages/codex-provider",
    "build:runtime": "tsc -b packages/runtime",
    "build:server": "bun run build:openpond && tsc -b apps/server",
    "bundle:server": "bun build apps/server/src/index.ts --target=node --external sqlite3 --external node-pty --outfile apps/server/dist/index.js",
    "build:terminal": "tsc -b apps/terminal",
    "build:web": "bun run --cwd apps/web build",
    "build:desktop": "tsc -b apps/desktop && bun build apps/desktop/src/main.ts --target=node --format=esm --external electron --outfile apps/desktop/dist/main.js && bun build apps/desktop/src/preload.ts --target=node --format=cjs --external electron --outfile apps/desktop/dist/preload.js",
    "stage:desktop": "bun scripts/stage-desktop-runtime.ts",
    "build:artifacts": "bun run bundle:server && bun run build:web && bun run build:desktop",
    "build": "bun run typecheck && bun run build:artifacts",
    "budgets:warn": "bun scripts/check-performance-budgets.ts",
    "budgets:check": "OPENPOND_BUDGETS_STRICT=1 bun scripts/check-performance-budgets.ts",
    "budgets:desktop-package": "bun scripts/check-desktop-package-budgets.ts",
    "budgets:cli": "bun run cli:build && bun run budgets:cli:check",
    "budgets:cli:check": "bun scripts/check-cli-distribution.ts",
    "structure:check": "bun scripts/check-source-structure.ts",
    "dependencies:check": "bun scripts/check-workspace-dependencies.ts",
    "cycles:server-runtime": "bun scripts/report-server-runtime-cycles.ts",
    "benchmark:turn-runtime": "bun scripts/benchmark-turn-runtime-queries.ts",
    "baseline:optimization": "bun scripts/capture-optimization-baseline.ts",
    "test": "bun scripts/run-tests.ts all",
    "test:unit": "bun scripts/run-tests.ts unit",
    "test:integration": "bun scripts/run-tests.ts integration",
    "test:contract": "bun scripts/run-tests.ts contract",
    "test:release": "bun scripts/run-tests.ts release",
    "test:cli": "bun scripts/run-tests.ts cli",
    "test:agent-sdk": "bun scripts/run-tests.ts agent-sdk",
    "test:live": "bun scripts/run-tests.ts live",
    "test:e2e": "bun scripts/run-tests.ts live",
    "verify:push": "bun scripts/verify-push.ts",
    "hooks:install": "bun scripts/install-git-hooks.ts",
    "prepare": "bun run hooks:install",
    "test:desktop:subagents": "bun scripts/desktop-harness.ts run tests/desktop-scenarios/subagent-suite.ts --isolated --timeout-ms 300000 --artifacts-dir tmp/desktop-harness/subagent-suite --json tmp/desktop-harness/subagent-suite/report.json",
    "smoke": "bun tests/smoke.ts",
    "smoke:codex": "OPENPOND_APP_LIVE_CODEX=1 bun tests/codex-live-smoke.ts",
    "smoke:desktop:dev": "bun scripts/smoke-dev-desktop.ts",
    "verify:desktop:compaction": "bun scripts/verify-context-compaction-desktop.ts",
    "smoke:desktop:packaged": "bun scripts/smoke-packaged-desktop.ts",
    "smoke:desktop:packaged:validate": "bun scripts/validate-packaged-smoke-reports.ts",
    "cli": "bun run --cwd apps/cli cli",
    "cli:dev": "bun run --cwd apps/cli dev",
    "cli:test": "bun test --cwd apps/cli",
    "cli:typecheck": "bun run --cwd apps/cli typecheck",
    "cli:build": "bun run --cwd apps/cli build",
    "cli:release:build": "bun scripts/build-cli-release.ts",
    "cli:pack:dry-run": "npm pack ./apps/cli --dry-run",
    "agent-sdk:build": "bun run --cwd packages/agent-sdk build",
    "agent-sdk:typecheck": "bun run --cwd packages/agent-sdk typecheck",
    "agent-sdk:test": "bun test --cwd packages/agent-sdk",
    "agent-sdk:check": "bun run --cwd packages/agent-sdk check",
    "release:stable": "bun scripts/release-stable.ts",
    "release:patch": "bun scripts/release-stable.ts patch",
    "release:minor": "bun scripts/release-stable.ts minor",
    "release:major": "bun scripts/release-stable.ts major",
    "release:inventory": "bun scripts/generate-release-inventory.ts",
    "release:sbom": "bun x @cyclonedx/cdxgen@12.2.0 -t js -o release-assets/openpond-sbom.cdx.json .",
    "package:linux": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --linux AppImage --publish never",
    "package:mac": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --mac zip --publish never",
    "package:win": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --win nsis --publish never",
    "package:linux:release": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --linux AppImage --publish never",
    "package:mac:release": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --mac zip --publish never",
    "package:win:release": "bun run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --win nsis --publish never",
    "package:win:docker": "bash scripts/package-win-docker.sh",
    "dist": "bun run build && bun run package:linux"
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shell-quote": "^1.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "description": "<div align=\"center\">   <h1>OpenPond</h1>   <p><strong>Frontier-grade agent orchestration for any model, provider, or subscription.</strong></p>   <p>     <a href=\"https://github.com/openpond/openpond/actions/workflows/ci.yml\"><img alt=\"CI\" src=\"https://github.com/openpond/openpond/actions/workflows/ci.yml/badge.svg\" /></a>     <a href=\"apps/cli\"><img alt=\"npm package status\" src=\"https://img.shields.io/badge/npm-unpublished-lightgrey?logo=npm&logoColor=white\" /></a>     <img alt=\"Runtime: Bun\" src=\"https://img.shields.io/badge/runtime-Bun-000000?logo=bun&logoColor=white\" />     <img alt=\"Language: TypeScript\" src=\"https://img.shields.io/badge/language-TypeScript-3178c6?logo=typescript&logoColor=white\" />   </p> </div>",
  "main": "preload.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpond/openpond.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/openpond/openpond/issues"
  },
  "homepage": "https://github.com/openpond/openpond#readme"
}
