{
  "name": "@openpond/workspace",
  "version": "0.0.30",
  "private": true,
  "openpondReleaseVersioned": true,
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "pnpm run dev:desktop",
    "desktop": "pnpm run dev:desktop",
    "dev:server": "tsx scripts/dev-runner.ts server",
    "dev:web": "tsx scripts/dev-runner.ts web",
    "dev:web:renderer": "tsx scripts/dev-runner.ts renderer",
    "dev:desktop": "tsx scripts/dev-runner.ts desktop",
    "start": "pnpm run dev",
    "serve": "pnpm run build:server && node apps/server/dist/index.js serve",
    "web": "pnpm run build:web && pnpm run build:server && node apps/server/dist/index.js web",
    "server": "pnpm run build:server && node apps/server/dist/index.js",
    "terminal": "tsx apps/terminal/src/index.ts chat",
    "typecheck": "tsc -b",
    "typecheck:turn-runner-contract": "tsc -p tests/tsconfig.turn-runner-contract.json",
    "build:cloud": "tsc -b packages/cloud",
    "build:openpond": "pnpm run build:cloud && pnpm --dir apps/cli run build",
    "build:contracts": "tsc -b packages/contracts",
    "build:codex": "tsc -b packages/codex-provider",
    "build:runtime": "tsc -b packages/runtime",
    "build:server": "pnpm run build:openpond && tsc -b apps/server",
    "bundle:server": "tsc -b apps/server && tsx scripts/build/bundle-server.ts",
    "build:terminal": "tsc -b apps/terminal",
    "build:web": "pnpm --dir apps/web run build",
    "build:desktop": "tsc -b apps/desktop && tsx scripts/build/bundle-desktop.ts",
    "electron:runtime:check": "tsx scripts/check-electron-runtime.ts",
    "stage:desktop": "tsx scripts/stage-desktop-runtime.ts",
    "build:artifacts": "pnpm run bundle:server && pnpm run build:web && pnpm run build:desktop",
    "build": "pnpm run typecheck && pnpm run build:artifacts",
    "budgets:warn": "tsx scripts/check-performance-budgets.ts",
    "budgets:check": "OPENPOND_BUDGETS_STRICT=1 tsx scripts/check-performance-budgets.ts",
    "budgets:desktop-package": "tsx scripts/check-desktop-package-budgets.ts",
    "budgets:cli": "pnpm run cli:build && pnpm run budgets:cli:check",
    "budgets:cli:check": "tsx scripts/check-cli-distribution.ts",
    "structure:check": "tsx scripts/check-source-structure.ts",
    "reachability:check": "tsx scripts/check-production-entrypoints.ts",
    "dependencies:check": "tsx scripts/check-workspace-dependencies.ts",
    "hygiene:check": "tsx scripts/check-repository-hygiene.ts && tsx scripts/check-node-toolchain.ts",
    "runtime:node-only:check": "tsx scripts/check-node-toolchain.ts",
    "workflows:check": "tsx scripts/check-workflows.ts && tsx scripts/run-actionlint.ts",
    "cycles:server-runtime": "tsx scripts/report-server-runtime-cycles.ts",
    "benchmark:turn-runtime": "tsx scripts/benchmark-turn-runtime-queries.ts",
    "baseline:optimization": "tsx scripts/capture-optimization-baseline.ts",
    "test": "tsx scripts/run-tests.ts all",
    "test:unit": "tsx scripts/run-tests.ts unit",
    "test:integration": "tsx scripts/run-tests.ts integration",
    "test:python": "uv run --project python/openpond-training --frozen pytest",
    "test:contract": "tsx scripts/run-tests.ts contract",
    "test:release": "tsx scripts/run-tests.ts release",
    "test:cli": "tsx scripts/run-tests.ts cli",
    "test:agent-sdk": "tsx scripts/run-tests.ts agent-sdk",
    "test:live": "tsx scripts/run-tests.ts live",
    "test:e2e": "tsx scripts/run-tests.ts live",
    "verify:quick": "pnpm run typecheck && OPENPOND_TEST_REUSE_BUILD=1 tsx scripts/run-tests.ts unit",
    "verify:push": "tsx scripts/verify-push.ts",
    "hooks:install": "tsx scripts/install-git-hooks.ts",
    "prepare": "tsx scripts/install-git-hooks.ts",
    "test:desktop:subagents": "tsx scripts/desktop-harness.ts run tests/desktop-scenarios/subagent-suite.ts --isolated --timeout-ms 300000 --artifacts-dir tmp/desktop-harness/subagent-suite --json tmp/desktop-harness/subagent-suite/report.json",
    "smoke": "tsx tests/smoke.ts",
    "smoke:codex": "OPENPOND_APP_LIVE_CODEX=1 tsx tests/codex-live-smoke.ts",
    "smoke:desktop:dev": "tsx scripts/smoke-dev-desktop.ts",
    "verify:desktop:compaction": "tsx scripts/verify-context-compaction-desktop.ts",
    "smoke:desktop:packaged": "tsx scripts/smoke-packaged-desktop.ts",
    "smoke:desktop:packaged:validate": "tsx scripts/validate-packaged-smoke-reports.ts",
    "cli": "pnpm --dir apps/cli run cli",
    "cli:dev": "pnpm --dir apps/cli run dev",
    "cli:test": "vitest run apps/cli/test",
    "cli:typecheck": "pnpm --dir apps/cli run typecheck",
    "cli:build": "pnpm run build:web && pnpm --dir apps/cli run build",
    "cli:pack:dry-run": "npm pack ./apps/cli --dry-run",
    "agent-sdk:build": "pnpm --dir packages/agent-sdk run build",
    "agent-sdk:typecheck": "pnpm --dir packages/agent-sdk run typecheck",
    "agent-sdk:test": "pnpm --dir packages/agent-sdk run test",
    "agent-sdk:check": "pnpm --dir packages/agent-sdk run check",
    "release:stable": "tsx scripts/release-stable.ts",
    "release:patch": "tsx scripts/release-stable.ts patch",
    "release:minor": "tsx scripts/release-stable.ts minor",
    "release:major": "tsx scripts/release-stable.ts major",
    "release:version:check": "tsx scripts/check-release-version.ts",
    "release:source-artifacts:stage": "tsx scripts/stage-release-source-artifacts.ts",
    "release:inventory": "tsx scripts/generate-release-inventory.ts",
    "release:sbom": "pnpm dlx @cyclonedx/cdxgen@12.2.0 -t js -o release-assets/openpond-sbom.cdx.json .",
    "package:linux": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --linux AppImage --publish never",
    "package:mac": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --mac zip --publish never",
    "package:win": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.json --win nsis --publish never",
    "package:linux:release": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --linux AppImage --publish never",
    "package:mac:release": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --mac zip --publish never",
    "package:win:release": "pnpm run stage:desktop && electron-builder --config apps/desktop/electron-builder.release.json --win nsis --publish never",
    "package:win:docker": "bash scripts/package-win-docker.sh",
    "dist": "pnpm run build && pnpm run package:linux"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@openpond/cloud": "workspace:*",
    "@openpond/codex-provider": "workspace:*",
    "@openpond/connected-apps": "workspace:*",
    "@openpond/contracts": "workspace:*",
    "@openpond/logging": "workspace:*",
    "@openpond/runtime": "workspace:*",
    "@types/node": "24.13.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "43.1.1",
    "electron-builder": "^26.0.12",
    "esbuild": "0.28.1",
    "openpond-agent-sdk": "workspace:*",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "vitest": "4.1.10",
    "zod": "^4.1.13"
  },
  "description": "<div align=\"center\">   <h1>OpenPond</h1>   <p><strong>Frontier-grade agent orchestration for any model, provider, or subscription.</strong></p>   <p>     <a href=\"https://github.com/openpond/openpond/actions/workflows/ci.yml\"><img alt=\"CI\" src=\"https://github.com/openpond/openpond/actions/workflows/ci.yml/badge.svg\" /></a>     <a href=\"apps/cli\"><img alt=\"npm package status\" src=\"https://img.shields.io/badge/npm-unpublished-lightgrey?logo=npm&logoColor=white\" /></a>     <img alt=\"Runtime: Node 24\" src=\"https://img.shields.io/badge/runtime-Node_24-339933?logo=nodedotjs&logoColor=white\" />     <img alt=\"Package manager: pnpm\" src=\"https://img.shields.io/badge/package_manager-pnpm-F69220?logo=pnpm&logoColor=white\" />     <img alt=\"Language: TypeScript\" src=\"https://img.shields.io/badge/language-TypeScript-3178c6?logo=typescript&logoColor=white\" />   </p> </div>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openpond/openpond.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/openpond/openpond/issues"
  },
  "homepage": "https://github.com/openpond/openpond#readme"
}
