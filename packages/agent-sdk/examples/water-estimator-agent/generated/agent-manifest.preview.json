{
  "schemaVersion": 1,
  "sourceOfTruth": "typescript",
  "project": {
    "name": "cloud-water-estimator-example",
    "version": "0.1.0",
    "useCase": "cloud-water-estimator",
    "description": "Construction drawing task planning and water-treatment estimate review."
  },
  "defaultEntrypoint": {
    "scope": "action",
    "name": "chat"
  },
  "runtime": {
    "base": "node-bun-workspace"
  },
  "resources": {
    "cpu": 2,
    "memoryGb": 4,
    "diskGb": 20
  },
  "instructions": null,
  "skills": [],
  "editable": {
    "kind": "editable",
    "enabled": true,
    "backend": "openpond-coding-work-item",
    "runtimeEnvironmentId": "openpond-coding-core-v1",
    "sourceOfTruth": "agent-source",
    "policyDiscovery": {
      "command": "openpond agent inspect --json",
      "runAfter": "source-materialized"
    },
    "allowedPaths": [
      "agent/**",
      "src/**",
      "package.json",
      "README.md"
    ],
    "requiredChecks": [
      "openpond-agent validate",
      "openpond-agent eval"
    ],
    "defaultResultMode": "patch_only",
    "supportedResultModes": [
      "patch_only",
      "commit_to_runtime_ref",
      "create_branch",
      "open_pr"
    ]
  },
  "setup": {
    "commands": [
      "mkdir -p artifacts volumes/drawing-plans/drawings volumes/drawing-plans/rendered volumes/drawing-plans/artifacts volumes/water-history/history volumes/water-history/proposals volumes/water-history/artifacts"
    ]
  },
  "validation": {
    "commands": [
      "test -f agent/agent.ts",
      "test -f agent/workflows/chat.ts",
      "command -v pdfinfo",
      "command -v pdftoppm"
    ]
  },
  "actions": [
    {
      "name": "chat",
      "description": "Shared conversational entrypoint for OpenPond Chat, Teams, Slack, MCP, API, and schedules.",
      "visibility": "default",
      "target": {
        "kind": "intent-router",
        "router": "chat-router",
        "intents": [
          "generate_task_plan",
          "generate_estimate_review",
          "task_plan_history",
          "task_plan_revision",
          "request_clarification"
        ],
        "defaultIntent": "request_clarification"
      },
      "timeoutSeconds": 10800,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/chat-result.json",
        "artifacts/openpond-trace.jsonl",
        "artifacts/drawing-render-manifest.json",
        "artifacts/drawing-rendered-pages.csv",
        "artifacts/sheet-index.json",
        "artifacts/page-extractions.json",
        "artifacts/consolidated-task-plan.json",
        "artifacts/task-plan.csv",
        "artifacts/task-plan.xlsx",
        "artifacts/task-plan-export.json",
        "artifacts/task-plan-ledger.json",
        "artifacts/example-estimate.json",
        "artifacts/example-estimate.csv",
        "artifacts/example-estimate.xlsx",
        "artifacts/search-results.json",
        "artifacts/proposal-review.json",
        "artifacts/sqlite-import-summary.json",
        "artifacts/microsoft-upload-refs.json",
        "artifacts/task-plan-history-answer.json",
        "artifacts/task-plan-history-candidates.json",
        "artifacts/task-plan-revision.json",
        "artifacts/task-plan-v2.csv",
        "artifacts/task-plan-v2.xlsx",
        "artifacts/task-plan-approved.csv",
        "artifacts/task-plan-approved.xlsx"
      ]
    },
    {
      "name": "generate-task-plan",
      "description": "Generate a task plan from drawing PDFs.",
      "visibility": "end_user",
      "target": {
        "kind": "workflow",
        "workflow": "generate-task-plan"
      },
      "timeoutSeconds": 10800,
      "inputSchema": "DrawingTaskPlanInput",
      "outputArtifacts": [
        "artifacts/drawing-render-manifest.json",
        "artifacts/drawing-rendered-pages.csv",
        "artifacts/sheet-index.json",
        "artifacts/page-extractions.json",
        "artifacts/consolidated-task-plan.json",
        "artifacts/task-plan.csv",
        "artifacts/task-plan.xlsx",
        "artifacts/task-plan-export.json",
        "artifacts/task-plan-ledger.json"
      ]
    },
    {
      "name": "render-drawings",
      "description": "Render drawing PDFs into page images.",
      "visibility": "debug",
      "target": {
        "kind": "workflow",
        "workflow": "render-drawings"
      },
      "timeoutSeconds": 1800,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/drawing-render-manifest.json",
        "artifacts/drawing-rendered-pages.csv"
      ]
    },
    {
      "name": "extract-sheet-index",
      "description": "Extract drawing sheet metadata from rendered pages.",
      "visibility": "debug",
      "target": {
        "kind": "workflow",
        "workflow": "extract-sheet-index"
      },
      "timeoutSeconds": 1800,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/sheet-index.json"
      ]
    },
    {
      "name": "extract-page-tasks",
      "description": "Extract task candidates from selected drawing pages.",
      "visibility": "debug",
      "target": {
        "kind": "workflow",
        "workflow": "extract-page-tasks"
      },
      "timeoutSeconds": 7200,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/page-extractions.json"
      ]
    },
    {
      "name": "consolidate-task-plan",
      "description": "Merge page-level extraction results into one task plan.",
      "visibility": "debug",
      "target": {
        "kind": "workflow",
        "workflow": "consolidate-task-plan"
      },
      "timeoutSeconds": 1800,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/consolidated-task-plan.json"
      ]
    },
    {
      "name": "export-task-plan",
      "description": "Export a consolidated task plan to CSV/XLSX and ledger files.",
      "visibility": "debug",
      "target": {
        "kind": "workflow",
        "workflow": "export-task-plan"
      },
      "timeoutSeconds": 1800,
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/consolidated-task-plan.json",
        "artifacts/task-plan.csv",
        "artifacts/task-plan.xlsx",
        "artifacts/task-plan-export.json",
        "artifacts/task-plan-ledger.json"
      ]
    },
    {
      "name": "generate-estimate",
      "description": "Review a proposal against historical water estimate files.",
      "visibility": "end_user",
      "target": {
        "kind": "workflow",
        "workflow": "generate-estimate-review"
      },
      "timeoutSeconds": 3600,
      "inputSchema": "EstimateReviewInput",
      "outputArtifacts": [
        "artifacts/example-estimate.json",
        "artifacts/example-estimate.csv",
        "artifacts/example-estimate.xlsx",
        "artifacts/search-results.json",
        "artifacts/proposal-review.json",
        "artifacts/sqlite-import-summary.json"
      ]
    },
    {
      "name": "task-plan-history",
      "description": "Search saved task-plan history on the durable water-history volume.",
      "visibility": "end_user",
      "target": {
        "kind": "workflow",
        "workflow": "task-plan-history"
      },
      "timeoutSeconds": 1800,
      "inputSchema": "TaskPlanHistoryInput",
      "outputArtifacts": [
        "artifacts/task-plan-history-answer.json",
        "artifacts/task-plan-history-candidates.json"
      ]
    },
    {
      "name": "revise-task-plan",
      "description": "Approve, reject, rename, export, or revise an existing task plan.",
      "visibility": "end_user",
      "target": {
        "kind": "workflow",
        "workflow": "task-plan-revision"
      },
      "timeoutSeconds": 1800,
      "inputSchema": "TaskPlanRevisionInput",
      "outputArtifacts": [
        "artifacts/task-plan-revision.json",
        "artifacts/task-plan-v2.csv",
        "artifacts/task-plan-v2.xlsx",
        "artifacts/task-plan-approved.csv",
        "artifacts/task-plan-approved.xlsx"
      ]
    }
  ],
  "chat": {
    "kind": "intent-router",
    "inputSchema": "AgentChatInput",
    "intents": [
      "generate_task_plan",
      "generate_estimate_review",
      "task_plan_history",
      "task_plan_revision",
      "request_clarification"
    ],
    "defaultIntent": "request_clarification",
    "routing": {
      "strategy": "model-or-code",
      "model": "openpond-chat",
      "traceSelection": true
    }
  },
  "workflows": [
    {
      "name": "generate-task-plan",
      "description": "Render drawings, extract sheet/task data, consolidate tasks, and export CSV/XLSX."
    },
    {
      "name": "generate-estimate-review",
      "description": "Import historical estimate files, review a proposal, and export an estimate package."
    },
    {
      "name": "render-drawings",
      "description": "Render drawing PDFs into page images and a render manifest."
    },
    {
      "name": "extract-sheet-index",
      "description": "Extract sheet index metadata from rendered drawing pages."
    },
    {
      "name": "extract-page-tasks",
      "description": "Extract page-level task candidates from drawings."
    },
    {
      "name": "consolidate-task-plan",
      "description": "Consolidate page-level extractions into one task plan."
    },
    {
      "name": "export-task-plan",
      "description": "Export a consolidated task plan to CSV, XLSX, and ledger artifacts."
    },
    {
      "name": "task-plan-history",
      "description": "Answer questions about saved task-plan runs and prior versions."
    },
    {
      "name": "task-plan-revision",
      "description": "Approve, reject, export, rename, or edit a generated task plan."
    }
  ],
  "channels": [
    {
      "id": "openpond_chat",
      "targetAction": "chat",
      "requiredConnections": [],
      "capabilities": [],
      "enabledByDefault": false
    },
    {
      "id": "microsoft_teams",
      "targetAction": "chat",
      "requiredConnections": [
        "microsoft_teams"
      ],
      "capabilities": [
        "microsoft_teams.message.ingest"
      ],
      "enabledByDefault": false
    },
    {
      "id": "slack",
      "targetAction": "chat",
      "requiredConnections": [
        "slack"
      ],
      "capabilities": [
        "slack.message.ingest"
      ],
      "enabledByDefault": false
    },
    {
      "id": "mcp",
      "targetAction": "chat",
      "requiredConnections": [],
      "capabilities": [],
      "enabledByDefault": false
    }
  ],
  "tools": [
    {
      "name": "generate_task_plan",
      "description": "Generate a construction drawing task plan from uploaded drawing PDFs.",
      "visibility": "end_user",
      "target": {
        "kind": "action",
        "action": "generate-task-plan",
        "workflow": "generate-task-plan"
      },
      "inputSchema": "DrawingTaskPlanInput",
      "outputArtifacts": [
        "artifacts/consolidated-task-plan.json",
        "artifacts/task-plan.csv",
        "artifacts/task-plan.xlsx"
      ]
    },
    {
      "name": "review_water_estimate",
      "description": "Review a proposal against historical water estimate files.",
      "visibility": "end_user",
      "target": {
        "kind": "action",
        "action": "generate-estimate",
        "workflow": "generate-estimate-review"
      },
      "inputSchema": "EstimateReviewInput",
      "outputArtifacts": [
        "artifacts/example-estimate.json",
        "artifacts/example-estimate.xlsx",
        "artifacts/proposal-review.json"
      ]
    },
    {
      "name": "revise_task_plan",
      "description": "Approve, reject, export, rename, or edit an existing task plan.",
      "visibility": "end_user",
      "target": {
        "kind": "action",
        "action": "revise-task-plan",
        "workflow": "task-plan-revision"
      },
      "inputSchema": "TaskPlanRevisionInput",
      "outputArtifacts": [
        "artifacts/task-plan-revision.json",
        "artifacts/task-plan-v2.xlsx",
        "artifacts/task-plan-approved.xlsx"
      ]
    },
    {
      "name": "lookup_task_plan_history",
      "description": "Search saved task-plan history stored on the durable water-history volume.",
      "visibility": "end_user",
      "target": {
        "kind": "action",
        "action": "task-plan-history",
        "workflow": "task-plan-history"
      },
      "inputSchema": "TaskPlanHistoryInput",
      "outputArtifacts": [
        "artifacts/task-plan-history-answer.json",
        "artifacts/task-plan-history-candidates.json"
      ]
    },
    {
      "name": "render_drawings",
      "description": "Render drawing PDFs to page images for debugging extraction behavior.",
      "visibility": "debug",
      "target": {
        "kind": "action",
        "action": "render-drawings"
      },
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/drawing-render-manifest.json",
        "artifacts/drawing-rendered-pages.csv"
      ]
    },
    {
      "name": "extract_sheet_index",
      "description": "Build the drawing sheet index from rendered pages and drawing metadata.",
      "visibility": "debug",
      "target": {
        "kind": "action",
        "action": "extract-sheet-index"
      },
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/sheet-index.json"
      ]
    },
    {
      "name": "extract_page_tasks",
      "description": "Extract task candidates from selected rendered drawing pages.",
      "visibility": "debug",
      "target": {
        "kind": "action",
        "action": "extract-page-tasks"
      },
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/page-extractions.json"
      ]
    },
    {
      "name": "export_task_plan",
      "description": "Export the consolidated task plan to CSV/XLSX.",
      "visibility": "debug",
      "target": {
        "kind": "action",
        "action": "export-task-plan"
      },
      "inputSchema": null,
      "outputArtifacts": [
        "artifacts/task-plan.csv",
        "artifacts/task-plan.xlsx",
        "artifacts/task-plan-export.json",
        "artifacts/task-plan-ledger.json"
      ]
    }
  ],
  "volumes": [
    {
      "name": "drawing-plans",
      "mountPath": "/workspace/volumes/drawing-plans",
      "description": "Input drawings, rendered pages, and extraction intermediates.",
      "storageGb": 8,
      "deleteOnSandboxDelete": false,
      "provisioning": {
        "mode": "select-or-create",
        "scope": "project",
        "selector": {
          "kind": "project-volume",
          "name": "drawing-plans",
          "labels": {
            "openpond.agent": "cloud-water-estimator-example",
            "openpond.volumeRole": "drawing-inputs"
          }
        },
        "create": {
          "storageGb": 8,
          "retention": "retain"
        },
        "ui": {
          "label": "Drawing plan volume",
          "description": "Select an existing drawing workspace or create a new one for uploaded plan PDFs.",
          "allowUpload": true,
          "required": true
        }
      },
      "state": {
        "engine": "filesystem"
      },
      "usedBy": [
        "generate-task-plan",
        "render-drawings",
        "extract-sheet-index",
        "extract-page-tasks"
      ]
    },
    {
      "name": "water-history",
      "mountPath": "/workspace/volumes/water-history",
      "description": "Durable task-plan history, ledgers, and proposal review state.",
      "storageGb": 8,
      "deleteOnSandboxDelete": false,
      "provisioning": {
        "mode": "select-or-create",
        "scope": "project",
        "selector": {
          "kind": "project-volume",
          "name": "water-history",
          "labels": {
            "openpond.agent": "cloud-water-estimator-example",
            "openpond.volumeRole": "history"
          }
        },
        "create": {
          "storageGb": 8,
          "retention": "retain"
        },
        "ui": {
          "label": "Water estimator history",
          "description": "Select the saved estimating history volume or create one for this project.",
          "required": true
        }
      },
      "state": {
        "engine": "sqlite",
        "files": [
          "history/task-plans.sqlite",
          "proposals/task-plans.sqlite"
        ],
        "concurrency": "single-writer-per-agent-run"
      },
      "usedBy": [
        "generate-estimate",
        "task-plan-history",
        "revise-task-plan"
      ]
    }
  ],
  "integrations": [
    {
      "provider": "opchat",
      "models": [
        "openpond-chat"
      ],
      "scopes": [
        "opchat:model:read",
        "opchat:chat:create"
      ]
    },
    {
      "provider": "microsoft_teams",
      "required": false,
      "capabilities": [
        "microsoft_teams.message.ingest"
      ]
    },
    {
      "provider": "slack",
      "required": false,
      "capabilities": [
        "slack.message.ingest"
      ]
    }
  ],
  "schedules": [
    {
      "kind": "schedule",
      "cron": "0 8 * * MON-FRI",
      "timezone": "America/New_York",
      "enabledByDefault": false,
      "target": {
        "action": "chat"
      },
      "input": {
        "prompt": "Summarize recent task-plan revisions and water estimate review items.",
        "channel": "schedule",
        "context": {
          "reportKind": "daily-estimate-digest"
        }
      },
      "name": "daily-estimate-digest",
      "scheduleType": "cron"
    }
  ],
  "evals": [
    {
      "name": "drawing-pdf-generates-task-plan",
      "description": "A drawing PDF should route to generate_task_plan and produce task-plan artifacts."
    },
    {
      "name": "history-and-proposal-routes-to-estimate-review",
      "description": "History spreadsheets and a proposal should route to the estimate-review workflow."
    },
    {
      "name": "empty-chat-asks-for-input",
      "description": "A generic request with no files should ask for the missing drawing/proposal/history context."
    }
  ]
}
