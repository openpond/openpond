    ],
    "evals": [
      "drawing-pdf-generates-task-plan",
      "history-and-proposal-routes-to-estimate-review",
      "empty-chat-asks-for-input"
    ],
    "volumes": [
      "drawing-plans",
      "water-history"
    ],
    "integrations": [
      "opchat",
      "microsoft_teams",
      "slack"
    ]
  },
  "validation": {
    "declaredCommands": [
      "test -f agent/agent.ts",
      "test -f agent/workflows/chat.ts",
      "command -v pdfinfo",
      "command -v pdftoppm"
    ],
    "requiredChecks": [
      "openpond-agent validate",
      "openpond-agent eval"
