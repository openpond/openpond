{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "openpond-agent-sdk": ["./src/index.ts"],
      "openpond-agent-sdk/*": ["./src/*/index.ts"]
    },
    "strict": true,
    "target": "ES2022",
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "examples/**/*.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
