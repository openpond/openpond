{
  "name": "openpond-agent-sdk",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "openpond-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./channels": {
      "types": "./dist/channels/index.d.ts",
      "import": "./dist/channels/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./editable": {
      "types": "./dist/editable/index.d.ts",
      "import": "./dist/editable/index.js"
    },
    "./eval": {
      "types": "./dist/eval/index.d.ts",
      "import": "./dist/eval/index.js"
    },
    "./instructions": {
      "types": "./dist/instructions/index.d.ts",
      "import": "./dist/instructions/index.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "import": "./dist/integrations/index.js"
    },
    "./inspect": {
      "types": "./dist/inspect/index.d.ts",
      "import": "./dist/inspect/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./schedules": {
      "types": "./dist/schedules/index.d.ts",
      "import": "./dist/schedules/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "import": "./dist/skills/index.js"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "import": "./dist/tracing/index.js"
    },
    "./validator": {
      "types": "./dist/validator/index.d.ts",
      "import": "./dist/validator/index.js"
    },
    "./volumes": {
      "types": "./dist/volumes/index.d.ts",
      "import": "./dist/volumes/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "tsx": "4.23.1",
    "yaml": "^2.9.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@openpond/connected-apps": "workspace:*",
    "@types/node": "24.13.3",
    "esbuild": "0.28.1",
    "vitest": "4.1.10",
    "typescript": "^5.9.3"
  },
  "openpondBundledSourceDependencies": [
    "@openpond/connected-apps"
  ],
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && vitest run --root ../.. --config vitest.config.ts --project agent-sdk",
    "inspect": "node ./dist/cli.js inspect --json",
    "agent:build": "node ./dist/cli.js build",
    "validate": "node ./dist/cli.js validate",
    "eval": "node ./dist/cli.js eval",
    "run": "node ./dist/cli.js run",
    "traces": "node ./dist/cli.js traces",
    "check:examples": "tsx ./scripts/check-examples.ts",
    "check:package-install": "tsx ./scripts/check-package-install.ts",
    "check:hygiene": "tsx ./scripts/check-hygiene.ts",
    "pack:dry-run": "npm pack --dry-run",
    "check": "pnpm run build && pnpm run typecheck && vitest run --root ../.. --config vitest.config.ts --project agent-sdk && pnpm run check:examples && pnpm run check:package-install && pnpm run check:hygiene && pnpm run pack:dry-run"
  }
}
