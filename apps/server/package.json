{
  "name": "@openpond/local-server",
  "version": "0.0.15",
  "main": "./dist/index.js",
  "dependencies": {
    "@openpond/cloud": "workspace:*",
    "@openpond/codex-provider": "workspace:*",
    "@openpond/contracts": "workspace:*",
    "@openpond/runtime": "workspace:*",
    "cron-parser": "^5.6.1",
    "node-pty": "^1.1.0",
    "shell-quote": "^1.9.0",
    "sqlite3": "^5.1.7",
    "ws": "^8.20.1",
    "zod": "^4.1.13"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "bin": {
    "openpond-app-server": "./dist/index.js"
  },
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "dev": "bun run --cwd ../.. build:server && node dist/index.js",
    "serve": "bun run --cwd ../.. build:server && node dist/index.js serve",
    "web": "bun run --cwd ../.. build:web && bun run --cwd ../.. build:server && node dist/index.js web"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
