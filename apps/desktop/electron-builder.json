{
  "appId": "ai.openpond.app",
  "productName": "openpond",
  "asar": true,
  "directories": {
    "app": "apps/desktop/stage/app",
    "output": "release",
    "buildResources": "apps/desktop/build"
  },
  "icon": "apps/desktop/build/icon.png",
  "afterPack": "scripts/after-pack.cjs",
  "files": [
    "dist/**/*",
    "package.json",
    "!node_modules/**/*"
  ],
  "npmRebuild": false,
  "extraMetadata": {
    "main": "dist/main.js"
  },
  "extraResources": [
    {
      "from": "apps/desktop/stage/runtime",
      "to": "."
    },
    {
      "from": "apps/desktop/build/icons",
      "to": "icons"
    },
    {
      "from": "LICENSE",
      "to": "LICENSE.openpond.txt"
    }
  ],
  "mac": {
    "icon": "apps/desktop/build/icon.icns",
    "category": "public.app-category.developer-tools",
    "identity": "-",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "OpenPond uses the microphone for local voice dictation."
    },
    "target": ["zip"]
  },
  "win": {
    "icon": "apps/desktop/build/icon.ico",
    "target": ["nsis"]
  },
  "linux": {
    "icon": "apps/desktop/build/icons",
    "target": ["AppImage"],
    "category": "Development",
    "desktop": {
      "entry": {
        "Name": "openpond",
        "Comment": "OpenPond desktop and local server app",
        "Icon": "openpond-app",
        "StartupWMClass": "openpond",
        "Categories": "Development;"
      }
    }
  }
}
