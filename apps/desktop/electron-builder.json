{
  "appId": "ai.openpond.app",
  "productName": "openpond",
  "asar": true,
  "directories": {
    "output": "release",
    "buildResources": "apps/desktop/build"
  },
  "icon": "apps/desktop/build/icon.png",
  "afterPack": "scripts/after-pack.cjs",
  "files": [
    "apps/desktop/dist/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "apps/desktop/dist/main.js"
  },
  "extraResources": [
    {
      "from": "apps/server/dist",
      "to": "server"
    },
    {
      "from": "node_modules/sqlite3",
      "to": "server/node_modules/sqlite3"
    },
    {
      "from": "node_modules/bindings",
      "to": "server/node_modules/bindings"
    },
    {
      "from": "node_modules/file-uri-to-path",
      "to": "server/node_modules/file-uri-to-path"
    },
    {
      "from": "node_modules/node-pty",
      "to": "server/node_modules/node-pty"
    },
    {
      "from": "node_modules/node-addon-api",
      "to": "server/node_modules/node-addon-api"
    },
    {
      "from": "apps/web/dist",
      "to": "web"
    },
    {
      "from": "apps/desktop/build/icons",
      "to": "icons"
    }
  ],
  "mac": {
    "icon": "apps/desktop/build/icon.icns",
    "category": "public.app-category.developer-tools",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "OpenPond uses the microphone for local voice dictation."
    },
    "target": ["zip"]
  },
  "win": {
    "icon": "apps/desktop/build/icon.ico",
    "target": ["nsis"]
  },
  "linux": {
    "icon": "apps/desktop/build/icons",
    "target": ["AppImage"],
    "category": "Development",
    "desktop": {
      "entry": {
        "Name": "openpond",
        "Comment": "OpenPond desktop and local server app",
        "Icon": "openpond-app",
        "StartupWMClass": "openpond",
        "Categories": "Development;"
      }
    }
  }
}
