{
  "name": "openpond",
  "version": "0.0.12",
  "description": "OpenPond CLI and local harness",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "openpond-code": "dist/cli.js",
    "openpond": "dist/cli.js",
    "op": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli/main.ts --tui",
    "cli": "bun run src/cli/main.ts",
    "cli:package": "bun run src/cli/main.ts",
    "clean": "node scripts/clean-dist.mjs",
    "build:cli": "bun build ./src/cli/main.ts --outfile=dist/cli.js --target=node --banner:js='#!/usr/bin/env node'",
    "build:package": "bun build src/index.ts src/sandbox-template/manifest.ts --outdir dist --target node",
    "build:types": "tsc --project tsconfig.package.json && node scripts/flatten-types.mjs",
    "lint": "npm run typecheck",
    "typecheck": "npm run build:types",
    "test": "bun test",
    "build": "npm run clean && npm run build:cli && npm run build:package && npm run build:types",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "npm run build && npm run changeset:publish"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "RELEASE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openpond/openpond"
  },
  "homepage": "https://github.com/openpond/openpond",
  "bugs": {
    "url": "https://github.com/openpond/openpond/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sandbox-template": {
      "import": "./dist/sandbox-template/manifest.js",
      "types": "./dist/sandbox-template/manifest.d.ts"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "typescript": "^5.6.3",
    "typescript-language-server": "^4.3.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.24"
  }
}
