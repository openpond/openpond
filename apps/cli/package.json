{
  "name": "openpond",
  "version": "0.0.33",
  "openpondReleaseVersioned": true,
  "license": "MIT",
  "description": "OpenPond CLI and local harness",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "openpond-code": "dist/cli.js",
    "openpond": "dist/cli.js",
    "op": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts --tui",
    "cli": "tsx src/cli/main.ts",
    "cli:package": "tsx src/cli/main.ts",
    "clean": "node scripts/clean-dist.mjs",
    "build:cli": "tsx ../../scripts/build/bundle-cli.ts cli",
    "build:package": "tsx ../../scripts/build/bundle-cli.ts package",
    "build:local-assets": "node scripts/stage-local-assets.mjs",
    "build:types": "tsc --project tsconfig.package.json && node scripts/flatten-types.mjs",
    "docs:commands": "tsx scripts/generate-command-reference.mjs",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run test",
    "build": "pnpm run clean && pnpm run docs:commands && pnpm run build:cli && pnpm run build:package && pnpm run build:local-assets && pnpm run build:types",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist/**/*",
    "docs/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "RELEASE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openpond/openpond"
  },
  "homepage": "https://github.com/openpond/openpond",
  "bugs": {
    "url": "https://github.com/openpond/openpond/issues"
  },
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sandbox-template": {
      "import": "./dist/sandbox-template/manifest.js",
      "types": "./dist/sandbox-template/manifest.d.ts"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "node-pty": "^1.1.0",
    "typescript": "^5.6.3",
    "typescript-language-server": "^4.3.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@openpond/cloud": "workspace:*",
    "@openpond/contracts": "workspace:*",
    "@openpond/local-server": "workspace:*",
    "@openpond/runtime": "workspace:*",
    "@openpond/terminal": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "24.13.3"
  },
  "openpondBundledSourceDependencies": [
    "@openpond/cloud",
    "@openpond/contracts",
    "@openpond/local-server",
    "@openpond/runtime",
    "@openpond/terminal"
  ]
}
